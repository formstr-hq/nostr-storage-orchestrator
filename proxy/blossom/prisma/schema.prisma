generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  BASIC
  PRO
}

model Blob {
  hash      String   @id
  npub      String
  size      BigInt
  replicas  String[]
  createdAt DateTime @default(now())

  user User @relation(fields: [npub], references: [npub])
}

model User {
  npub        String @id
  plan        Plan   @default(FREE)
  usedStorage BigInt @default(0)
  createdAt   DateTime @default(now())
  
  blobs       Blob[]
}